# ============================================================
# TWD Sales Assistant — environment variables template
# Copy this file to .env and fill in the values.
# Never commit .env to git.
# ============================================================

# --- Required ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-key

# --- Optional: enables the /api/research endpoint ---
# Get a key from https://portal.azure.com → Bing Search v7
BING_SEARCH_API_KEY=

# --- Optional: restrict CORS to specific frontend origins ---
# Comma-separated list of allowed origins.
# Defaults to http://localhost:3000 and http://localhost:5173 if not set.
# Example for production: ALLOWED_ORIGINS=https://sales.twd.nl
ALLOWED_ORIGINS=

# --- Future: Azure AD SSO (not active yet) ---
# Fill these in once the App Registration is set up in Azure Portal.
# No code changes needed — the auth module picks them up automatically.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
